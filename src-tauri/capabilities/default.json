{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for MatrixOS main window",
  "windows": ["main", "background"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-open",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default"
  ]
}
