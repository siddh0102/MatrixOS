# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/

# Tauri build artifacts
src-tauri/target/

# Generated Tauri capability schemas (regenerated on build)
src-tauri/gen/

# SQLite database (user data, never commit)
*.db
*.db-shm
*.db-wal

# Environment & secrets
.env
.env.*
!.env.example

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
.nyc_output/

# TanStack Router generated route tree
src/routeTree.gen.ts

# TypeScript cache
*.tsbuildinfo

# Vite cache
.vite/

# Vitest cache
.vitest/

# Tauri icons (generated — regenerate with: npm run tauri icon)
src-tauri/icons/

# dev.bat / start.bat contain no secrets but are machine-specific (hardcoded paths)
dev.bat
start.bat

# Design/planning docs (keep opendesign.md, exclude scratch files)
phase1_open.md

# Claude Code machine-local overrides (the .local.json suffix is Claude's convention for per-user state)
.claude/settings.local.json
CLAUDE.md

# ONNX model binaries — too large for git; downloaded/placed at install time
*.onnx
